{
  "name": "computer-iai-one-monorepo",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev:web": "pnpm --filter ./apps/web dev",
    "dev:mobile": "pnpm --filter ./apps/mobile start",
    "dev:api": "pnpm --filter ./apps/api dev",
    "web:build": "pnpm --filter ./apps/web build",
    "web:preview": "pnpm --filter ./apps/web preview",
    "api:dev": "pnpm --filter ./apps/api dev",
    "api:build": "pnpm --filter ./apps/api build",
    "build:web": "pnpm --filter ./apps/web build",
    "build:api": "pnpm --filter ./apps/api build",
    "typecheck:web": "pnpm --filter ./apps/web exec tsc --noEmit",
    "typecheck:mobile": "pnpm --filter ./apps/mobile exec tsc --noEmit",
    "typecheck:api": "pnpm --filter ./apps/api exec tsc --noEmit",
    "typecheck": "pnpm run typecheck:web && pnpm run typecheck:mobile && pnpm run typecheck:api",
    "build": "pnpm run build:web && pnpm run build:api",
    "check": "pnpm run typecheck && pnpm run build",
    "verify": "pnpm run check"
  }
}
